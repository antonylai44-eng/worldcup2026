PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:4000

# football-data.org, simpler local option for World Cup code WC
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# Sportmonks Football API 3.0
SPORTMONKS_API_TOKEN=replace_me
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_WORLD_CUP_SEASON_ID=replace_with_provider_season_id

# API-Football predictions
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_HOST=
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=
API_FOOTBALL_SEASON=

# Optional: The Odds API for outright champion/futures odds.
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_MATCH_SPORT_KEY=soccer_fifa_world_cup
ODDS_API_WORLD_CUP_OUTRIGHT_SPORT_KEY=soccer_fifa_world_cup_winner
ODDS_API_REGIONS=us,uk,eu

# World Football Elo Ratings TSV source. Cached for 12 hours.
ELO_RATINGS_BASE_URL=https://www.eloratings.net
